set -e
set +e
if [ -n "$D" ]; then
    ln -sf zImage-6.19.0-rc8-00186-g0627e308924b $D/boot/zImage > /dev/null 2>&1
else
    ln -sf zImage-6.19.0-rc8-00186-g0627e308924b boot/zImage > /dev/null 2>&1
    if [ $? -ne 0 ]; then
        echo "Filesystem on boot/ doesn't support symlinks, falling back to copied image (zImage)."
        install -m 0644 boot/zImage-6.19.0-rc8-00186-g0627e308924b boot/zImage
    fi
fi
set -e
